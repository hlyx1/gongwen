# DeepSeek AI服务配置（开发环境）
# 请将 your-api-key-here 替换为你的 DeepSeek API 密钥

# DeepSeek API地址
VITE_AI_BASE_URL=https://api.deepseek.com/chat/completions

# 模型名称（deepseek-chat 或 deepseek-reasoner ）
VITE_AI_MODEL=deepseek-reasoner

# API密钥（请替换为你的实际密钥）
VITE_AI_API_KEY=your-api-key

# 温度参数（可选，默认0.3）
VITE_AI_TEMPERATURE=0.7

# 最大token数
VITE_AI_MAX_TOKENS=65536
